vg>
    <div class="topbar-divider"></div>
    <div class="topbar-title">Guardiões do Clima 2026</div>
</div>

<div class="app">
    <div class="header">
        <h1>Sorteio de <em>Casas</em></h1>
        <p id="instruction" style="font-weight: 600; color: var(--muted); margin-top: 10px;">Clique no botão para iniciar</p>
    </div>

    <div class="teams-grid" id="results-grid"></div>

    <div class="controls">
        <button class="btn-draw" id="btn-draw" onclick="startFullRaffle()">Iniciar Sorteio</button>
    </div>
</div>

<script>
const TEAMS_DATA = [
    { id: 0, name: "SENNA", color: "#e85d8a", bg: "rgba(232,93,138,0.15)", avatar: "https://s7d1.scene7.com/is/image/Targetwebmotors/casa-senna?fmt=png-alpha&hei=519&wid=489", members: ["Mariana", "Eliana", "Lais", "Daniel", "Raphael", "Heitor", "Rebeca", "Murilo"] },
    { id: 1, name: "VETTEL", color: "#5d9ee8", bg: "rgba(93,158,232,0.15)", avatar: "https://s7d1.scene7.com/is/image/Targetwebmotors/casa-vettel?fmt=png-alpha&hei=636&wid=836", members: ["Daniel", "Chico", "Rodrigo Tarifa", "Arjuna", "Rodrigo Matias", "Natalia", "Nicole", "Jarder", "Giulia"] },
    { id: 2, name: "LAUDA", color: "#e8a25d", bg: "rgba(232,162,93,0.15)", avatar: "https://s7d1.scene7.com/is/image/Targetwebmotors/casa-lauda?fmt=png-alpha&hei=232&wid=233", members: ["Daniela", "Filipe", "Jefferson", "Fabio", "Caio", "William", "Patricia", "Nathalya", "Pedro"] },
    { id: 3, name: "PROST", color: "#5de89e", bg: "rgba(93,232,158,0.15)", avatar: "https://s7d1.scene7.com/is/image/Targetwebmotors/casa-prost?fmt=png-alpha&hei=361&wid=418", members: ["Adriana", "Peixe", "Rafael", "Deucimara", "Jesse", "Jaqueline", "Camila", "Daniele", "Leticia"] },
    { id: 4, name: "HAMILTON", color: "#c45de8", bg: "rgba(196,93,232,0.15)", avatar: "https://s7d1.scene7.com/is/image/Targetwebmotors/casa-hamilton?fmt=png-alpha&hei=485&wid=435", members: ["Thiago", "Vivaldo", "Paulinha", "Maria", "Lucas", "Alina", "Gustavo", "Vinicius"] },
    { id: 5, name: "VERSTAPPEN", color: "#e8d15d", bg: "rgba(232,209,93,0.15)", avatar: "https://s7d1.scene7.com/is/image/Targetwebmotors/casa-verstappen?fmt=png-alpha&hei=552&wid=552", members: ["Felipe", "Raphael", "Robson", "Vitoria", "Diego", "Maycol", "Vitor", "Demetrio"] },
    { id: 6, name: "NORIS", color: "#5dd4e8", bg: "rgba(93,212,232,0.15)", avatar: "https://s7d1.scene7.com/is/image/Targetwebmotors/casa-noris?fmt=png-alpha&hei=474&wid=431", members: ["Jessica", "Caio", "Virginia", "Henrique", "Gustavo", "Veronica", "Dennis", "Victor", "Andressa"] }
];

let selectedTeams = [];

function createSlots() {
    const grid = document.getElementById('results-grid');
    grid.innerHTML = '';
    for(let i=0; i<4; i++) {
        grid.innerHTML += `
            <div class="team-card" id="slot-${i}">
                <div id="content-${i}">
                    <div class="team-logo" style="background: #eee"></div>
                    <div class="team-name" style="color: #ccc">AGUARDANDO</div>
                </div>
            </div>
        `;
    }
}

async function startFullRaffle() {
    const btn = document.getElementById('btn-draw');
    btn.disabled = true;
    
    createSlots();
    
    const shuffled = [...TEAMS_DATA].sort(() => 0.5 - Math.random());
    const finalTeams = shuffled.slice(0, 4);
    selectedTeams = finalTeams;

    for (let i = 0; i < 4; i++) {
        const slot = document.getElementById(`slot-${i}`);
        slot.classList.add('spinning-effect', 'active');
        
        let ticks = 0;
        const maxTicks = 10 + (i * 4); 

        await new Promise(resolve => {
            const interval = setInterval(() => {
                const randomTeam = TEAMS_DATA[Math.floor(Math.random() * TEAMS_DATA.length)];
                updateSlotUI(i, randomTeam);
                ticks++;

                if (ticks >= maxTicks) {
                    clearInterval(interval);
                    updateSlotUI(i, finalTeams[i], true);
                    slot.classList.remove('spinning-effect');
                    slot.classList.add('finalized');
                    resolve();
                }
            }, 70);
        });
    }

    btn.disabled = false;
    document.getElementById('instruction').innerHTML = "Casas sorteadas! Clique nelas para os nomes.";
}

function updateSlotUI(index, team, isFinal = false) {
    const container = document.getElementById(`content-${index}`);
    const slot = document.getElementById(`slot-${index}`);
    
    if(isFinal) {
        slot.style.setProperty('--team-color', team.color);
        container.innerHTML = `
            <div class="team-logo" style="background: ${team.bg}">
                <img src="${team.avatar}" alt="${team.name}">
            </div>
            <div class="team-name" style="color: ${team.color}">${team.name}</div>
            <div class="member-box" id="member-box-${index}" onclick="drawMember(${index})">
                <div class="winner-label">Representante</div>
                <div class="winner-name" id="winner-name-${index}">Sortear Nome</div>
            </div>
        `;
    } else {
        container.innerHTML = `
            <div class="team-logo" style="background: #eee; opacity: 0.5">
                <img src="${team.avatar}" alt="${team.name}" style="filter: grayscale(1)">
            </div>
            <div class="team-name" style="color: #999">${team.name}</div>
        `;
    }
}

async function drawMember(index) {
    const box = document.getElementById(`member-box-${index}`);
    const nameEl = document.getElementById(`winner-name-${index}`);
    
    if (box.classList.contains('spinning')) return;

    box.classList.remove('revealed');
    box.classList.add('spinning');
    nameEl.style.color = "var(--text)"; 
    
    const team = selectedTeams[index];
    let ticks = 0;
    const maxTicks = 12;

    const interval = setInterval(() => {
        const tempName = team.members[Math.floor(Math.random() * team.members.length)];
        nameEl.textContent = tempName;
        ticks++;

        if (ticks >= maxTicks) {
            clearInterval(interval);
            const finalName = team.members[Math.floor(Math.random() * team.members.length)];
            nameEl.textContent = finalName;
            box.classList.remove('spinning');
            box.classList.add('revealed');
            nameEl.style.color = team.name;
        }
    }, 80);
}

// Inicia os slots vazios ao carregar
createSlots();
</script>

</body>
</html>
