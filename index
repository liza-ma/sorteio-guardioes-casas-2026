<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Guardiões do Clima 2026 — Sorteio de Times</title>
<link href="https://fonts.googleapis.com/css2?family=Figtree:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
:root {
    --red: #F3123C;
    --red-dark: #c80e30;
    --dark: #F4F3F8;
    --dark2: #FFFFFF;
    --border: rgba(24,23,31,0.12);
    --text: #18171F;
    --muted: #525060;
}

* { margin: 0; padding: 0; box-sizing: border-box; }
body {
    font-family: 'Figtree', sans-serif;
    background: var(--dark);
    color: var(--text);
    min-height: 100vh;
}

body::before {
    content: ''; position: fixed; inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none; z-index: 0;
}

.topbar {
    background: white;
    border-bottom: 2px solid var(--border);
    padding: 18px 32px;
    display: flex; align-items: center; gap: 20px;
    position: sticky; top: 0; z-index: 100;
}

.topbar-divider { width: 1px; height: 22px; background: var(--border); }
.topbar-title { font-weight: 700; font-size: 0.85rem; letter-spacing: 1.5px; text-transform: uppercase; }

.app { max-width: 1100px; margin: 0 auto; padding: 40px 24px; position: relative; z-index: 1; }
.header { text-align: center; margin-bottom: 40px; }
.header h1 { font-weight: 900; font-size: 3rem; letter-spacing: -1px; }
.header h1 em { font-style: normal; color: var(--red); }

.teams-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 20px;
    margin-bottom: 40px;
}

.team-card {
    background: var(--dark2);
    border: 2px solid var(--border);
    border-radius: 24px;
    padding: 30px 20px;
    text-align: center;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    min-height: 320px;
    display: flex; flex-direction: column; justify-content: center;
}

.team-card.active { border-color: var(--team-color); transform: scale(1.05); }

.team-logo {
    width: 110px; height: 110px; margin: 0 auto 15px;
    border-radius: 50%; padding: 12px;
    display: flex; align-items: center; justify-content: center;
}
.team-logo img { width: 100%; height: 100%; object-fit: contain; }

.team-name { font-weight: 900; font-size: 1.5rem; text-transform: uppercase; margin-bottom: 5px; }

.member-box {
    margin-top: 20px; padding: 15px; border-radius: 16px;
    background: #f8f8fc; border: 2px dashed var(--border);
    cursor: pointer; transition: all 0.2s;
    opacity: 0; transform: translateY(10px);
}

.team-card.finalized .member-box { opacity: 1; transform: translateY(0); }
.member-box.revealed { border-style: solid; background: white; border-color: var(--team-color); }

.winner-label { font-size: 0.7rem; font-weight: 800; text-transform: uppercase; letter-spacing: 2px; color: var(--muted); }
.winner-name { font-size: 1.25rem; font-weight: 900; color: var(--text); margin-top: 5px; }

.spinning-effect { animation: flicker 0.1s infinite; }
@keyframes flicker {
    0% { opacity: 0.5; transform: scale(0.98); }
    100% { opacity: 1; transform: scale(1); }
}

.controls { text-align: center; margin-top: 40px; }
.btn-draw {
    background: var(--red); color: white; border: none;
    padding: 20px 60px; border-radius: 20px; font-weight: 900;
    font-size: 1.2rem; text-transform: uppercase; cursor: pointer;
    box-shadow: 0 10px 20px rgba(243,18,60,0.2);
    transition: transform 0.2s;
}
.btn-draw:active { transform: scale(0.95); }
.btn-draw:disabled { background: #ccc; cursor: not-allowed; opacity: 0.7; }
</style>
</head>
<body>

<div class="topbar">
